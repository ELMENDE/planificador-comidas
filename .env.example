# ── Supabase ──────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Claude / Anthropic (usado en Edge Function) ───────────
# No va en el cliente, va en los secrets de Supabase Edge Functions

# ── Sentry (crash reporting) ──────────────────────────────
# Obtener en: sentry.io → Settings → Projects → tu proyecto → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
