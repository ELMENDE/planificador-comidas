{
  "expo": {
    "name": "Planificador",
    "slug": "planificador-comidas",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "planificador",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff7ed"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.usuario.planificador",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["planificador"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff7ed"
      },
      "package": "com.usuario.planificador",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "planificador", "host": "invitar", "pathPrefix": "/" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "@sentry/react-native/expo",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-widgets",
        {
          "ios": {
            "widgetName": "ComidaHoyWidget",
            "widgetDisplayName": "Comida de Hoy"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
